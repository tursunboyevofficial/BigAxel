# Copy to .env.local (gitignored) for local development with `vercel dev`.
# On Vercel production, add the same keys in Project Settings → Environment Variables.

# Bot token from @BotFather. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs where applications should be delivered.
# Use positive ids for private chats, negative ids for groups / supergroups.
# Example: TELEGRAM_CHAT_IDS=123456789,-1001234567890
TELEGRAM_CHAT_IDS=

# Random secret used to protect /api/telegram-chats (chat id discovery endpoint).
# Generate any long random string.
TELEGRAM_ADMIN_KEY=
